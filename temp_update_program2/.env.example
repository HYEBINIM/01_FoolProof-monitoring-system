# 장비 식별 정보
DEVICE_ID=FoolProof_01
# 이 풀프루프 장비의 고유 ID (예: FoolProof_01, FoolProof_02 등)
# 각 풀프루프마다 다른 ID를 설정해야 합니다

MACHINE_NUMBER=1
# 이 장비의 호기 번호 (1, 2, 3 등)
# dr1, er1 테이블의 id와 result1 테이블의 mc_code에 사용됩니다

# 소스 데이터베이스 (이 풀프루프 장비의 로컬 DB)
SOURCE_DB_HOST=127.0.0.1
SOURCE_DB_PORT=3306
SOURCE_DB_USER=root
SOURCE_DB_PASSWORD=your_password
SOURCE_DB_NAME=dataset

# 타겟 데이터베이스 (키오스크 원격 DB)
TARGET_DB_HOST=192.168.1.100
TARGET_DB_PORT=3306
TARGET_DB_USER=root
TARGET_DB_PASSWORD=your_password
TARGET_DB_NAME=dataset

# 동기화 설정
SYNC_INTERVAL=1000
# 동기화 주기 (밀리초, 5000 = 5초)

# 로그 설정
LOG_LEVEL=info
# debug, info, warn, error
